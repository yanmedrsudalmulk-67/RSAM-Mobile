{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data for patients and admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama_pasien": { "type": "string" },
        "nik": { "type": "string" },
        "tanggal_lahir": { "type": "string" },
        "jenis_kelamin": { "type": "string" },
        "alamat": { "type": "string" },
        "no_hp": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "patient"] },
        "foto_profil": { "type": "string" },
        "no_bpjs": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["nama_pasien", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Patient appointment booking data",
      "type": "object",
      "properties": {
        "id_booking": { "type": "string" },
        "user_id": { "type": "string" },
        "nama_pasien": { "type": "string" },
        "nik": { "type": "string" },
        "tanggal_lahir": { "type": "string" },
        "jenis_kelamin": { "type": "string" },
        "nomor_hp": { "type": "string" },
        "alamat": { "type": "string" },
        "jenis_jaminan": { "type": "string" },
        "nomor_bpjs": { "type": "string" },
        "poli": { "type": "string" },
        "dokter": { "type": "string" },
        "tanggal_kunjungan": { "type": "string" },
        "time": { "type": "string" },
        "nomor_antrian": { "type": "string" },
        "jenis_vaksin": { "type": "string" },
        "status_antrian": { "type": "string" },
        "waktu_booking": { "type": "string", "format": "date-time" },
        "file_ktp_kk": { "type": "string" },
        "file_passport": { "type": "string" },
        "tanggal_upload": { "type": "string" },
        "id_jadwal": { "type": "string" }
      }
    },
    "VaccineStock": {
      "title": "VaccineStock",
      "description": "Stock of vaccines available",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama_vaksin": { "type": "string" },
        "stok_tersedia": { "type": "integer" },
        "last_update": { "type": "string" }
      }
    },
    "EICVStock": {
      "title": "EICVStock",
      "description": "Stock of EICV",
      "type": "object",
      "properties": {
        "jumlah_stok": { "type": "integer" },
        "terakhir_update": { "type": "string" }
      }
    },
    "Poliklinik": {
      "title": "Poliklinik",
      "description": "Poliklinik data",
      "type": "object",
      "properties": {
        "id_poli": { "type": "string" },
        "nama_poli": { "type": "string" },
        "deskripsi": { "type": "string" },
        "lokasi_ruangan": { "type": "string" },
        "status_poli": { "type": "string" },
        "kuota_harian": { "type": "integer" }
      }
    },
    "Dokter": {
      "title": "Dokter",
      "description": "Doctor data",
      "type": "object",
      "properties": {
        "id_dokter": { "type": "string" },
        "nama_dokter": { "type": "string" },
        "spesialis": { "type": "string" },
        "poli": { "type": "string" },
        "jadwal_praktek": { "type": "string" },
        "is_rekomendasi": { "type": "boolean" },
        "urutan_rekomendasi": { "type": "integer" }
      }
    },
    "JadwalLayanan": {
      "title": "JadwalLayanan",
      "description": "Service schedule data",
      "type": "object",
      "properties": {
        "id_jadwal": { "type": "string" },
        "nama_poli": { "type": "string" },
        "nama_dokter": { "type": "string" },
        "hari_praktek": { "type": "string" },
        "jam_mulai": { "type": "string" },
        "jam_selesai": { "type": "string" },
        "status_layanan": { "type": "string" },
        "kuota_terpakai": { "type": "integer" },
        "cuti_mulai": { "type": "string" },
        "cuti_selesai": { "type": "string" }
      }
    },
    "Artikel": {
      "title": "Artikel",
      "description": "Hospital portal articles",
      "type": "object",
      "properties": {
        "id_artikel": { "type": "string" },
        "judul_artikel": { "type": "string" },
        "kategori_artikel": { "type": "string" },
        "ringkasan_artikel": { "type": "string" },
        "isi_artikel": { "type": "string" },
        "gambar_slider": { "type": "string" },
        "tanggal_publish": { "type": "string" },
        "status_publish": { "type": "string" },
        "featured_slider": { "type": "string" },
        "penulis": { "type": "string" },
        "tanggal_dibuat": { "type": "string" },
        "views": { "type": "integer" }
      }
    },
    "MedicalRecord": {
      "title": "MedicalRecord",
      "description": "Patient medical record data",
      "type": "object",
      "properties": {
        "id_booking": { "type": "string" },
        "id_pasien": { "type": "string" },
        "keluhan": { "type": "string" },
        "pemeriksaan": { "type": "string" },
        "tekanan_darah": { "type": "string" },
        "nadi": { "type": "integer" },
        "respirasi": { "type": "integer" },
        "suhu": { "type": "number" },
        "saturasi": { "type": "integer" },
        "diagnosa": { "type": "string" },
        "tindakan": { "type": "string" },
        "obat": { "type": "array", "items": { "type": "string" } },
        "dosis": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "ICD-10 Diagnosis codes",
      "type": "object",
      "properties": {
        "kode": { "type": "string" },
        "nama": { "type": "string" }
      }
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Available medicines",
      "type": "object",
      "properties": {
        "nama": { "type": "string" },
        "satuan": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "bookings": {
      "schema": "Booking",
      "description": "Collection of patient bookings"
    },
    "vaccine_stocks": {
      "schema": "VaccineStock",
      "description": "Collection of vaccine stocks"
    },
    "eicv_stock": {
      "schema": "EICVStock",
      "description": "Document for EICV stock"
    },
    "poliklinik": {
      "schema": "Poliklinik",
      "description": "Collection of poliklinik"
    },
    "dokter": {
      "schema": "Dokter",
      "description": "Collection of doctors"
    },
    "jadwal_layanan": {
      "schema": "JadwalLayanan",
      "description": "Collection of service schedules"
    },
    "artikel": {
      "schema": "Artikel",
      "description": "Collection of articles"
    },
    "rekam_medis": {
      "schema": "MedicalRecord",
      "description": "Collection of medical records"
    },
    "diagnosa": {
      "schema": "Diagnosis",
      "description": "Collection of diagnosis codes"
    },
    "obat": {
      "schema": "Medicine",
      "description": "Collection of medicines"
    }
  }
}
